{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Test",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/${input:testTarget}",
            "args": [
                "--gtest_filter=${input:testFilter}"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build"
        }
    ],
    "inputs": [
        {
            "id": "testTarget",
            "type": "pickString",
            "description": "Which test binary to debug?",
            "options": [
                "disk_test",
                "lru_replacer_test",
                "lruk_replacer_test",
                "disk_scheduler_test",
                "buffer_pool_test",
                "table_page_test",
                "table_heap_test"
            ],
            "default": "table_heap_test"
        },
        {
            "id": "testFilter",
            "type": "promptString",
            "description": "GTest filter (e.g. TableHeapTest.MultiplePageSpillTest, or * for all)",
            "default": "*"
        }
    ]
}
